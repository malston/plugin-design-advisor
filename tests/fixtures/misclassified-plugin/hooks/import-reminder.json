{
  "hooks": [
    {
      "event": "PostToolUse",
      "matcher": {
        "tool_name": "Write"
      },
      "steps": [
        {
          "type": "command",
          "command": "echo 'Reminder: check your import ordering in the file you just wrote.'"
        }
      ]
    }
  ]
}

<!-- ANTI-PATTERN: hook-without-suppression
     This hook fires on every Write event regardless of file type, whether the
     file has imports, or whether the reminder was already shown this session.
     It produces noise on every file write (CSS, JSON, markdown, etc.) and
     trains users to ignore hook output. Needs path filtering and session-level
     suppression to avoid redundant firings. -->
